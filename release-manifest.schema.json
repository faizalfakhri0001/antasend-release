{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schemaVersion", "tag", "sourceRepository", "sourceSha", "builtAt", "components", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"const": 1},
    "tag": {"type": "string", "pattern": "^deploy-[0-9a-f]{40}-[0-9]{14}$"},
    "sourceRepository": {"const": "faizalfakhri0001/api-pilot"},
    "sourceSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "builtAt": {"type": "string", "format": "date-time"},
    "components": {"type": "object", "required": ["backend", "frontend"], "additionalProperties": false, "properties": {"backend": {"type": "boolean"}, "frontend": {"type": "boolean"}}},
    "artifacts": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"type": "object", "required": ["name", "sha256"], "additionalProperties": false, "properties": {"name": {"enum": ["backend-release-linux-amd64.tar.gz", "frontend-vercel-prebuilt.tar.gz"]}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}}
  }
}
